# Crypto Auto Trader — Environment Variables
# Copy to .env and fill in your values.
# Alternative to config/ JSON files — env vars take precedence.
#
# NEVER commit .env — it's in .gitignore

# Telegram Bot
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Revolut X API
REVX_API_KEY=your_api_key_here

# Revolut X signing key (base64-encoded PEM)
# Generate with: base64 -w0 config/private.pem
REVX_PRIVATE_KEY_B64=base64_encoded_pem_here
